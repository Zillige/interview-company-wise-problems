{
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/companies$", "dest": "/companies.html" },

    { "src": "^/api/companies$", "dest": "/api/companies" },
    { "src": "^/api/problems$", "dest": "/api/problems" },
    { "src": "^/api/company-progress$", "dest": "/api/company-progress" },

    { "src": "/(.*)", "dest": "/$1" }
  ]
}
